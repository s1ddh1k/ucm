{
  "name": "ucm-desktop",
  "version": "0.2.0",
  "private": true,
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "predev:main": "echo 'skipping legacy contract validation'",
    "dev:main": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 file:dist-electron/main/index.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "validate:role-contracts": "node scripts/validate-role-contracts.mjs",
    "prebuild:main": "echo 'skipping legacy contract validation'",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "test:runtime": "npm run build:main && node --test test/execution-service.test.mjs test/runtime-index-repository.test.mjs test/runtime-store.test.mjs test/workspace-browser-service.test.mjs test/workspace-discovery.test.mjs",
    "test:smoke": "npm run build && node --test --test-force-exit test/electron-smoke.mjs"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "node-pty": "^1.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^37.4.0",
    "playwright": "^1.58.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "wait-on": "^8.0.5"
  }
}
