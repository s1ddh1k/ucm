{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucm.local/schemas/artifacts/evidence-pack.schema.json",
  "title": "Evidence Pack",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "missionId": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "decision": {
      "type": "string",
      "enum": ["insufficient", "promote_to_review", "promote_to_completion"]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["pass", "warn", "fail"]
          },
          "summary": { "type": "string", "minLength": 1 },
          "artifactIds": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "required": ["name", "status", "summary"]
      }
    },
    "artifactIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "riskSummary": {
      "type": "array",
      "items": { "type": "string" }
    },
    "openQuestions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "generatedAtLabel": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "minLength": 1 }
  },
  "required": ["id", "decision", "checks", "artifactIds"],
  "anyOf": [
    { "required": ["generatedAtLabel"] },
    { "required": ["generatedAt"] }
  ]
}
