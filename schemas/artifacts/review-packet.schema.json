{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucm.local/schemas/artifacts/review-packet.schema.json",
  "title": "Review Packet",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "summary": { "type": "string", "minLength": 1 },
    "selectedApproach": { "type": "string", "minLength": 1 },
    "artifactIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "evidencePackIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "functionalStatus": {
      "type": "string",
      "enum": ["pass", "warn", "fail"]
    },
    "visualStatus": {
      "type": "string",
      "enum": ["pass", "warn", "fail", "not_applicable"]
    },
    "bugRiskStatus": {
      "type": "string",
      "enum": ["pass", "warn", "fail"]
    },
    "smokeStatus": {
      "type": "string",
      "enum": ["pass", "warn", "fail", "not_applicable"]
    },
    "surfacesReviewed": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "knownIssues": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "openRisks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requestedAction": {
      "type": "string",
      "enum": ["review", "approve", "steer"]
    }
  },
  "required": [
    "summary",
    "selectedApproach",
    "artifactIds",
    "evidencePackIds",
    "functionalStatus",
    "visualStatus",
    "bugRiskStatus",
    "smokeStatus",
    "surfacesReviewed",
    "knownIssues",
    "openRisks",
    "requestedAction"
  ]
}
