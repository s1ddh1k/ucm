{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucm.local/schemas/artifacts/decision-record.schema.json",
  "title": "Decision Record",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "category": {
      "type": "string",
      "enum": ["planning", "technical", "risk", "approval", "orchestration"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "rationale": { "type": "string", "minLength": 1 }
  },
  "required": ["id", "category", "summary", "rationale"]
}
