{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucm.local/schemas/artifacts/deliverable-revision.schema.json",
  "title": "Deliverable Revision",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "deliverableId": { "type": "string", "minLength": 1 },
    "deliverableKind": { "type": "string", "minLength": 1 },
    "revisionId": { "type": "string", "minLength": 1 },
    "revisionNumber": { "type": "integer", "minimum": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "basedOnArtifactIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "status": {
      "type": "string",
      "enum": ["active", "approved", "superseded"]
    }
  },
  "required": [
    "deliverableId",
    "deliverableKind",
    "revisionId",
    "revisionNumber",
    "summary",
    "basedOnArtifactIds",
    "status"
  ]
}
