{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucm.local/schemas/artifacts/architecture-record.schema.json",
  "title": "Architecture Record",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "systemContext": { "type": "string", "minLength": 1 },
    "majorComponents": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "criticalFlows": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "constraints": { "type": "array", "items": { "type": "string" } }
  },
  "required": ["systemContext", "majorComponents", "criticalFlows", "constraints"]
}
