{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucm.local/schemas/artifacts/rollback-plan.schema.json",
  "title": "Rollback Plan",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "summary": { "type": "string", "minLength": 1 },
    "triggerConditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "rollbackSteps": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "verificationSteps": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "required": ["summary", "triggerConditions", "rollbackSteps", "verificationSteps"]
}
