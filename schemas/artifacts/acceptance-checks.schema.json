{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucm.local/schemas/artifacts/acceptance-checks.schema.json",
  "title": "Acceptance Checks",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "blocking": { "type": "boolean" },
          "verificationMethod": {
            "type": "string",
            "enum": ["test", "review", "metric", "manual"]
          },
          "severity": {
            "type": "string",
            "enum": ["must", "should", "nice_to_have"]
          }
        },
        "required": ["id", "description", "blocking", "verificationMethod", "severity"]
      }
    }
  },
  "required": ["checks"]
}
