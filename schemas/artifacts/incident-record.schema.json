{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucm.local/schemas/artifacts/incident-record.schema.json",
  "title": "Incident Record",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "summary": { "type": "string", "minLength": 1 },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "affectedMissionId": { "type": "string", "minLength": 1 },
    "affectedRunId": { "type": "string", "minLength": 1 },
    "symptoms": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "nextActions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "required": ["summary", "severity", "affectedMissionId", "affectedRunId", "symptoms", "nextActions"]
}
