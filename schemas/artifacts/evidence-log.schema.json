{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucm.local/schemas/artifacts/evidence-log.schema.json",
  "title": "Evidence Log",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "claim": { "type": "string", "minLength": 1 },
          "source": {
            "type": "string",
            "enum": ["provider", "mock", "local"]
          },
          "capturedAt": { "type": "string", "minLength": 1 },
          "confidence": {
            "type": "string",
            "enum": ["inferred", "observed", "verified"]
          }
        },
        "required": ["id", "claim", "source", "capturedAt", "confidence"]
      }
    }
  },
  "required": ["entries"]
}
