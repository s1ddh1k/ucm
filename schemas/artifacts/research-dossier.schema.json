{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucm.local/schemas/artifacts/research-dossier.schema.json",
  "title": "Research Dossier",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "question": { "type": "string", "minLength": 1 },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "sourceIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "confidence": {
      "type": "string",
      "enum": ["inferred", "observed", "verified"]
    },
    "updatedAt": { "type": "string", "minLength": 1 }
  },
  "required": ["question", "findings", "sourceIds", "confidence", "updatedAt"]
}
