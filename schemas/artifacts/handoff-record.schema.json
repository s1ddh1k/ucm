{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucm.local/schemas/artifacts/handoff-record.schema.json",
  "title": "Handoff Record",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "deliverableRevisionId": { "type": "string", "minLength": 1 },
    "channel": {
      "type": "string",
      "enum": ["inbox", "share", "export"]
    },
    "target": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["active", "approved", "superseded"]
    },
    "relatedArtifactIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "required": ["deliverableRevisionId", "channel", "target", "status", "relatedArtifactIds"]
}
