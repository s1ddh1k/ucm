{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucm.local/schemas/artifacts/task-backlog.schema.json",
  "title": "Task Backlog",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "objective": { "type": "string", "minLength": 1 },
          "ownerRole": { "type": "string", "minLength": 1 }
        },
        "required": ["id", "title", "objective", "ownerRole"]
      }
    }
  },
  "required": ["tasks"]
}
