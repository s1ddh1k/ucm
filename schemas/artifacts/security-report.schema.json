{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucm.local/schemas/artifacts/security-report.schema.json",
  "title": "Security Report",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "summary": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["pass", "warn", "fail"]
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "status": {
            "type": "string",
            "enum": ["pass", "warn", "fail"]
          },
          "summary": { "type": "string", "minLength": 1 }
        },
        "required": ["id", "severity", "status", "summary"]
      }
    },
    "affectedArtifactIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "requestedAction": {
      "type": "string",
      "enum": ["observe", "review", "block"]
    }
  },
  "required": ["summary", "status", "findings", "affectedArtifactIds", "requestedAction"]
}
