{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucm.local/schemas/artifacts/run-trace.schema.json",
  "title": "Run Trace",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "runId": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "checkpoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "at": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 }
        },
        "required": ["at", "summary"]
      }
    }
  },
  "required": ["runId", "objective", "checkpoints"]
}
